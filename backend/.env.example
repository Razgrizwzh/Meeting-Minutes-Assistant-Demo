# ============================================================
# 会议纪要助手 —— 环境变量示例
# 用法：复制本文件为 .env 并填入真实值（.env 不会被提交）
# 注意：.env 需保存为 UTF-8 无 BOM，否则首键名可能带 BOM 导致读取失败
# ============================================================

# 阿里云百炼 API Key
DASHSCOPE_API_KEY=

# OpenAI 兼容端点（业务空间专属 key 用专属兼容端点；公网兼容端点作备选）
DASHSCOPE_BASE_URL=https://ws-uimefetm2aof0i9u.cn-beijing.maas.aliyuncs.com/compatible-mode/v1

# 模型名
CHAT_MODEL=qwen-plus
EMBEDDING_MODEL=text-embedding-v3

# JWT 密钥 —— 本文件不内置可用默认值（修正点 #6）
# 未设置时，config.py 会在启动时生成一个临时密钥并打印醒目告警
# （临时密钥重启后失效，已签发的 token 将无法验证）
# 生成长期密钥：python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=

# JWT 有效期（天）
JWT_EXPIRE_DAYS=7

# 存储路径（相对 backend/ 运行目录）
CHROMA_DB_PATH=./data/chroma_db
MEETINGS_DATA_PATH=./data/meetings
USERS_FILE_PATH=./data/users.json

# 跨域允许来源（逗号分隔，Vite 默认端口 5173）
CORS_ORIGINS=http://localhost:5173
